          "string": [
            {
              "value1": "={{ $json.retry_decision }}",
              "operation": "equal",
              "value2": "retry_approved"
            }
          ]
        }
      },
      "name": "Retry Decision Gate",
      "type": "n8n-nodes-base.if",
      "position": [1340, 300],
      "id": "retry-decision-gate",
      "typeVersion": 1
    },
    {
