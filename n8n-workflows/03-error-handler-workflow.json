              "value": "={{ $json.workflow_name }}"
            },
            {
              "name": "service_affected", 
              "value": "={{ $json.service_name }}"
            }
          ]
        },
        "options": {
          "timeout": 10000
        }
      },
      "name": "Send Critical Alert",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 200],
      "id": "send-critical-alert",
      "typeVersion": 1
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.is_retryable }}",
              "operation": "equal",
              "value2": true
            }
          ]
        }
      },
      "name": "Retryable Check",
      "type": "n8n-nodes-base.if",
      "position": [900, 400],
      "id": "retryable-check",
      "typeVersion": 1
    },
    {
      "parameters": {
        "functionCode": "// Implement exponential backoff retry logic\nconst retryCount = $json.retry_count || 0;\nconst maxRetries = 3;\nconst baseDelay = 2000; // 2 seconds\n\nif (retryCount >= maxRetries) {\n  return [{\n    json: {\n      ...$json,\n      retry_decision: 'max_retries_exceeded',\n      final_failure: true,\n      next_action: 'dead_letter_queue'\n    }\n  }];\n}\n\nconst delayMs = baseDelay * Math.pow(2, retryCount);\nconst jitter = Math.random() * 1000; // Add jitter to prevent thundering herd\nconst finalDelay = delayMs + jitter;\n\nreturn [{\n  json: {\n    ...$json,\n    retry_decision: 'retry_approved',\n    retry_count: retryCount + 1,\n    retry_delay_ms: finalDelay,\n    retry_at: new Date(Date.now() + finalDelay).toISOString(),\n    next_action: 'schedule_retry'\n  }\n}];"
      },
      "name": "Calculate Retry Strategy",
      "type": "n8n-nodes-base.function",
      "position": [1120, 300],
      "id": "calculate-retry",
      "typeVersion": 1
    },
    {
