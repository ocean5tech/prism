{
  "name": "Global Error Handler",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST", 
        "path": "error-handler",
        "responseMode": "responseNode",
        "options": {}
      },
      "name": "Error Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300],
      "id": "error-webhook",
      "webhookId": "global-error-handler",
      "typeVersion": 1
    },
    {
      "parameters": {
        "functionCode": "// Parse and categorize error\nconst errorData = $json;\nconst errorType = this.categorizeError(errorData);\nconst severity = this.determineSeverity(errorData);\nconst retryable = this.isRetryable(errorData);\n\nreturn [{\n  json: {\n    ...errorData,\n    error_category: errorType,\n    severity_level: severity,\n    is_retryable: retryable,\n    error_timestamp: new Date().toISOString(),\n    correlation_id: `err-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`\n  }\n}];\n\n// Helper functions\nfunction categorizeError(error) {\n  if (error.statusCode >= 500) return 'service_error';\n  if (error.statusCode === 429) return 'rate_limit';\n  if (error.statusCode >= 400 && error.statusCode < 500) return 'client_error';\n  if (error.message?.includes('timeout')) return 'timeout';\n  if (error.message?.includes('network')) return 'network';\n  return 'unknown';\n}\n\nfunction determineSeverity(error) {\n  if (error.statusCode >= 500) return 'high';\n  if (error.statusCode === 429) return 'medium';\n  if (error.message?.includes('timeout')) return 'medium';\n  return 'low';\n}\n\nfunction isRetryable(error) {\n  const retryableCodes = [408, 429, 500, 502, 503, 504];\n  const retryableMessages = ['timeout', 'network', 'connection'];\n  \n  if (retryableCodes.includes(error.statusCode)) return true;\n  if (retryableMessages.some(msg => error.message?.toLowerCase().includes(msg))) return true;\n  return false;\n}"
      },
      "name": "Categorize Error",
      "type": "n8n-nodes-base.function",
      "position": [460, 300],
      "id": "categorize-error",
      "typeVersion": 1
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.severity_level }}",
              "operation": "equal",
              "value2": "high"
            }
          ]
        }
      },
      "name": "High Severity Check",
      "type": "n8n-nodes-base.if",
      "position": [680, 300],
      "id": "high-severity-check",
      "typeVersion": 1
    },
